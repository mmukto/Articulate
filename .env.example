# The AI coach is provider-switchable. Set ONE of the keys below.
# If both are set, Gemini (free) is used unless you override with
# ARTICULATE_PROVIDER below.

# --- Option A: Google Gemini (free tier, recommended) ---
# Get a free key at https://aistudio.google.com/app/apikey  (no credit card)
GEMINI_API_KEY=
# Optional: override the Gemini model (defaults to gemini-2.0-flash)
# GEMINI_MODEL=gemini-2.0-flash

# --- Option B: Anthropic Claude (paid) ---
# Get a key at https://console.anthropic.com/
ANTHROPIC_API_KEY=
# Optional: override the Claude model (defaults to claude-opus-4-8)
# ANTHROPIC_MODEL=claude-opus-4-8

# --- Optional: force a provider regardless of which keys are present ---
# ARTICULATE_PROVIDER=gemini   # or: claude
