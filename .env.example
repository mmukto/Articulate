# The AI coach is provider-switchable. Set ONE of the keys below.
# If both are set, Gemini (free) is used unless you override with
# ARTICULATE_PROVIDER below.

# --- Option A: Google Gemini (free tier, recommended) ---
# Get a free key at https://aistudio.google.com/app/apikey  (no credit card)
GEMINI_API_KEY=
# Optional: override the Gemini model (defaults to gemini-2.5-flash-lite)
# GEMINI_MODEL=gemini-2.5-flash-lite

# --- Option B: Anthropic Claude (paid) ---
# Get a key at https://console.anthropic.com/
ANTHROPIC_API_KEY=
# Optional: override the Claude model (defaults to claude-opus-4-8)
# ANTHROPIC_MODEL=claude-opus-4-8

# --- Optional: force a provider regardless of which keys are present ---
# ARTICULATE_PROVIDER=gemini   # or: claude

# --- Per-user limits (signed-in users only) ---
# Each signed-in user gets a fixed access window and a hard spend cap, so one
# account can never run up the AI bill. Defaults: $2 over 365 days from sign-up.
# Override either without a code change:
# USER_ANNUAL_BUDGET_USD=2
# USER_ACCESS_DAYS=365

# --- Authentication (Clerk) — OPTIONAL ---
# Leave these blank to run auth-disabled: every page works, drills are
# practiceable, and progress is saved locally (no accounts, no cross-device
# sync). Set both keys to enable sign up / login and per-account progress.
# Create a free app at https://dashboard.clerk.com and copy both keys.
NEXT_PUBLIC_CLERK_PUBLISHABLE_KEY=
CLERK_SECRET_KEY=
